# Application
APP_NAME=Mahakosh
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-secure-random-string-min-32-chars

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Mahakosh

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mahakosh
POSTGRES_USER=mahakosh
POSTGRES_PASSWORD=mahakosh_secret

DATABASE_URL=postgresql+asyncpg://mahakosh:mahakosh_secret@postgres:5432/mahakosh
DATABASE_SYNC_URL=postgresql://mahakosh:mahakosh_secret@postgres:5432/mahakosh

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=mahakosh_minio
MINIO_SECRET_KEY=mahakosh_minio_secret
MINIO_BUCKET=mahakosh-documents
MINIO_USE_SSL=false

# Temporal
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mahakosh-workflows

# Ollama
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Knowledge Base / Embeddings
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_FALLBACK_MODEL=nomic-embed-text
RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DIMENSION=1024
CHUNK_SIZE_TOKENS=1000
CHUNK_OVERLAP_TOKENS=150
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
QDRANT_COLLECTION_PREFIX=mahakosh

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Nginx
NGINX_PORT=80
